### Example environment variables for local development and Vercel
# Client-side Vite variables (must start with VITE_ for browser code)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-side variables (used by SSR or server functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-service-role-or-publishable-key

# Other secrets the app may require (examples)
# NEXT_PUBLIC_SOME_KEY=...

README: Copy this file to `.env` for local development and fill in real values.
# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Add any other environment variables your app needs here
